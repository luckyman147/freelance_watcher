[
  {
    "name": "JobScraperTimer",
    "scriptFile": "AzureWatcher.Function.dll",
    "entryPoint": "AzureWatcher.Function.Functions.JobScraperFunction.RunAsync",
    "language": "dotnet-isolated",
    "properties": {
      "IsCodeless": false
    },
    "bindings": [
      {
        "name": "myTimer",
        "direction": "In",
        "type": "timerTrigger",
        "schedule": "0 */5 * * * *",
        "properties": {}
      }
    ]
  }
]